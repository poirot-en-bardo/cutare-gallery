---
import artists from '../data/artists.json';

const artistCount = artists.length;
---

<div class="landing">
  <div class="landing-media">
    <img src="images/landing.webp" alt="Galeria Cutare" />
  </div>

  <div class="landing-content">
    <div class="landing-content-inner">
      <h1 class="landing-title">Galeria<br/>Cutare.</h1>
      <p class="landing-text">
        Spațiu dedicat artei contemporane, aflat în Câmpulung Muscel. Aducem în atenția publicului lucrări ale artiștilor locali și creăm un loc de întâlnire pentru comunitatea artistică.
      </p>

      <nav class="landing-nav" aria-label="Explorează">
        <a href="expozitii/" class="landing-link">
          <span class="landing-link-text">Expoziții</span>
          <span class="landing-link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="artisti/" class="landing-link">
          <span class="landing-link-text">Artiști</span>
          <span class="landing-link-count" aria-label={`${artistCount} artiști`}>{artistCount}</span>
        </a>
        <a href="contact/" class="landing-link">
          <span class="landing-link-text">Contact</span>
          <span class="landing-link-arrow" aria-hidden="true">→</span>
        </a>
      </nav>
    </div>
  </div>
</div>

<style>
  .landing {
    display: grid;
    grid-template-columns: 1fr;
    min-height: calc(100svh - 7rem);
    overflow: hidden;
  }

  /* --- image side --- */
  .landing-media {
    position: relative;
    overflow: hidden;
    max-height: 50svh;
  }

  .landing-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- content side --- */
  .landing-content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
  }

  .landing-content-inner {
    max-width: 420px;
    width: 100%;
  }

  .landing-title {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(2.8rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }

  .landing-text {
    font-family: 'Newsreader', 'Times New Roman', serif;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 300;
    line-height: 1.7;
    color: var(--muted-readable);
    margin: 0 0 2.5rem;
  }

  /* --- navigation links --- */
  .landing-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
  }

  .landing-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .landing-link:last-child {
    border-bottom: 1px solid var(--line);
  }

  .landing-link:hover {
    color: var(--accent);
  }

  .landing-link-text {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .landing-link-arrow {
    font-size: 1.1rem;
    transition: transform 0.2s ease;
  }

  .landing-link:hover .landing-link-arrow {
    transform: translateX(4px);
  }

  .landing-link-count {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--highlight);
    border: 1px solid color-mix(in srgb, var(--highlight) 35%, transparent);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  /* --- desktop: side-by-side --- */
  @media (min-width: 800px) {
    .landing {
      grid-template-columns: 1fr 1fr;
      min-height: calc(100svh - 5rem);
    }

    .landing-media {
      max-height: none;
      height: 100%;
    }

    .landing-content {
      padding: 3rem 3.5rem;
    }

    .landing-title {
      font-size: clamp(3rem, 4.5vw, 4.5rem);
      margin-bottom: 2rem;
    }

    .landing-text {
      margin-bottom: 3rem;
    }
  }

  @media (min-width: 1100px) {
    .landing {
      grid-template-columns: 55% 45%;
    }

    .landing-content {
      padding: 4rem;
    }
  }
</style>
