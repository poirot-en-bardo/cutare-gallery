---
import artists from '../data/artists.json';

const artistCount = artists.length;
---

<div class="landing">
  <div class="landing-canvas" aria-hidden="true">
    <div class="landing-line landing-line--1"></div>
    <div class="landing-line landing-line--2"></div>
    <div class="landing-line landing-line--3"></div>
    <div class="landing-dot landing-dot--1"></div>
    <div class="landing-dot landing-dot--2"></div>
  </div>

  <div class="landing-center">
    <div class="landing-sketch" aria-hidden="true">
      <svg viewBox="0 0 320 220" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Ground line -->
        <path d="M10 195 Q80 193 160 195 Q240 197 310 195" stroke="var(--ink)" stroke-width="0.8" opacity="0.25"/>
        <!-- Main building body -->
        <path d="M62 195 L62 92 Q63 90 65 89 L155 89 Q157 90 158 92 L158 195" stroke="var(--ink)" stroke-width="1" opacity="0.4" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Roof -->
        <path d="M55 92 L110 52 L165 92" stroke="var(--ink)" stroke-width="1" opacity="0.4" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Roof ridge detail -->
        <path d="M110 52 L110 42" stroke="var(--accent)" stroke-width="0.8" opacity="0.5" stroke-linecap="round"/>
        <circle cx="110" cy="40" r="2.5" fill="var(--highlight)" opacity="0.4"/>
        <!-- Windows row 1 -->
        <rect x="75" y="102" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <rect x="103" y="102" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <rect x="131" y="102" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <!-- Windows row 2 -->
        <rect x="75" y="135" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <rect x="103" y="135" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <rect x="131" y="135" width="14" height="20" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.3"/>
        <!-- Door -->
        <path d="M101 195 L101 170 Q101 165 106 165 L114 165 Q119 165 119 170 L119 195" stroke="var(--ink)" stroke-width="0.8" opacity="0.35" stroke-linecap="round"/>
        <!-- Tower (Turnul Colții inspired) -->
        <path d="M200 195 L200 105 L240 105 L240 195" stroke="var(--ink)" stroke-width="1" opacity="0.35" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Tower top -->
        <path d="M195 105 L220 62 L245 105" stroke="var(--ink)" stroke-width="1" opacity="0.35" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Tower spire -->
        <path d="M220 62 L220 48" stroke="var(--accent)" stroke-width="0.8" opacity="0.45" stroke-linecap="round"/>
        <!-- Tower windows -->
        <rect x="211" y="118" width="18" height="14" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.25"/>
        <rect x="211" y="145" width="18" height="14" rx="1" stroke="var(--ink)" stroke-width="0.7" opacity="0.25"/>
        <path d="M215 195 L215 175 Q215 172 220 172 Q225 172 225 175 L225 195" stroke="var(--ink)" stroke-width="0.7" opacity="0.25" stroke-linecap="round"/>
        <!-- Trees / foliage sketches -->
        <circle cx="38" cy="170" r="16" stroke="var(--accent)" stroke-width="0.6" opacity="0.18" fill="none"/>
        <circle cx="42" cy="165" r="12" stroke="var(--accent)" stroke-width="0.6" opacity="0.15" fill="none"/>
        <path d="M38 186 L38 195" stroke="var(--ink)" stroke-width="0.6" opacity="0.2" stroke-linecap="round"/>
        <circle cx="272" cy="172" r="14" stroke="var(--accent)" stroke-width="0.6" opacity="0.18" fill="none"/>
        <circle cx="268" cy="168" r="10" stroke="var(--accent)" stroke-width="0.6" opacity="0.15" fill="none"/>
        <path d="M272 186 L272 195" stroke="var(--ink)" stroke-width="0.6" opacity="0.2" stroke-linecap="round"/>
        <!-- Accent brush stroke -->
        <path d="M45 205 Q110 202 180 205 Q250 208 290 205" stroke="var(--highlight)" stroke-width="1.5" opacity="0.15" stroke-linecap="round"/>
      </svg>
    </div>
    <p class="landing-text">
      <strong class="landing-text-name">Galeria Cutare</strong> este un spațiu dedicat artei contemporane, aflat în Câmpulung Muscel. Ne propunem să aducem în atenția publicului lucrări ale artiștilor locali și să creăm un spațiu de întâlnire pentru comunitatea artistică și iubitorii de artă.
    </p>
  </div>

  <nav class="landing-nav" aria-label="Explorează">
    <a href="expozitii/" class="landing-link">
      <span class="landing-link-text">Expoziții</span>
      <span class="landing-link-arrow" aria-hidden="true">→</span>
    </a>
    <a href="artisti/" class="landing-link">
      <span class="landing-link-text">Artiști</span>
      <span class="landing-link-count" aria-label={`${artistCount} artiști`}>{artistCount}</span>
    </a>
    <a href="contact/" class="landing-link">
      <span class="landing-link-text">Contact</span>
      <span class="landing-link-arrow" aria-hidden="true">→</span>
    </a>
  </nav>
</div>

<style>
  .landing {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100svh - 7rem);
    padding: 2rem 1.5rem 3rem;
    overflow: hidden;
  }

  /* --- abstract background lines --- */
  .landing-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.35;
  }

  .landing-line {
    position: absolute;
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in oklab, var(--accent) 30%, transparent),
      transparent
    );
    width: 1px;
  }

  .landing-line--1 {
    left: 18%;
    top: 8%;
    height: 40%;
    transform: rotate(12deg);
  }

  .landing-line--2 {
    right: 22%;
    bottom: 5%;
    height: 35%;
    transform: rotate(-8deg);
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in oklab, var(--highlight) 25%, transparent),
      transparent
    );
  }

  .landing-line--3 {
    left: 55%;
    top: 20%;
    height: 55%;
    transform: rotate(-3deg);
  }

  .landing-dot {
    position: absolute;
    border-radius: 50%;
  }

  .landing-dot--1 {
    width: 6px;
    height: 6px;
    background: var(--highlight);
    left: 28%;
    top: 35%;
    opacity: 0.5;
  }

  .landing-dot--2 {
    width: 4px;
    height: 4px;
    background: var(--accent);
    right: 30%;
    bottom: 30%;
    opacity: 0.4;
  }

  /* --- center content --- */
  .landing-center {
    position: relative;
    text-align: center;
    margin-bottom: 3rem;
    max-width: 520px;
  }

  .landing-sketch {
    width: min(280px, 70vw);
    margin: 0 auto 2rem;
  }

  .landing-sketch svg {
    width: 100%;
    height: auto;
  }

  .landing-text {
    font-family: 'Newsreader', 'Times New Roman', serif;
    font-size: clamp(1.05rem, 2.5vw, 1.2rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--muted-readable);
    margin: 0;
    text-align: center;
  }

  .landing-text-name {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 600;
    font-size: 1.15em;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  /* --- navigation links --- */
  .landing-nav {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: min(320px, 100%);
  }

  .landing-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .landing-link:last-child {
    border-bottom: 1px solid var(--line);
  }

  .landing-link:hover {
    color: var(--accent);
  }

  .landing-link-text {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .landing-link-arrow {
    font-size: 1.1rem;
    transition: transform 0.2s ease;
  }

  .landing-link:hover .landing-link-arrow {
    transform: translateX(4px);
  }

  .landing-link-count {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--highlight);
    border: 1px solid color-mix(in srgb, var(--highlight) 35%, transparent);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  /* --- responsive --- */
  @media (min-width: 700px) {
    .landing {
      min-height: calc(100svh - 5rem);
    }

    .landing-sketch {
      width: min(340px, 50vw);
    }

    .landing-nav {
      flex-direction: row;
      gap: 0;
      width: min(540px, 100%);
    }

    .landing-link {
      flex: 1;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      padding: 1.25rem 1rem;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      border-left: none;
      border-right: none;
    }

    .landing-link:last-child {
      border-bottom: 1px solid var(--line);
    }

    .landing-link + .landing-link {
      border-left: 1px solid var(--line);
    }

    .landing-link-arrow {
      font-size: 0.9rem;
    }
  }

  @media (min-width: 900px) {
    .landing-dot--1 {
      width: 8px;
      height: 8px;
    }

    .landing-dot--2 {
      width: 6px;
      height: 6px;
    }
  }
</style>
