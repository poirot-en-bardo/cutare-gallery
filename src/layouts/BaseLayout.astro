---
import '../styles/global.css';
import { withBase } from '../utils/withBase';
import { getPhoneTel, siteContact } from '../data/siteContact';
import { siteMeta } from '../data/siteMeta';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const pageUrl = Astro.url.toString();
const siteUrl = new URL(base, Astro.url.origin).toString();
const metaDescription = description ?? siteMeta.defaultDescription;
const metaImage = image ? new URL(image, Astro.url).toString() : undefined;
const phoneDigits = getPhoneTel();
const internationalPhone = phoneDigits.startsWith('0') ? `+4${phoneDigits}` : `+${phoneDigits}`;
const normalizedPath =
  pathname.startsWith(base) ? `/${pathname.slice(base.length)}` : pathname;
const isArtisti = normalizedPath === '/artisti/' || normalizedPath.startsWith('/artisti/');
const isLocatii = normalizedPath === '/locatii/' || normalizedPath.startsWith('/locatii/');
const isContact = normalizedPath === '/contact/' || normalizedPath.startsWith('/contact/');
const isExpoziții = normalizedPath === '/expozitii/' || normalizedPath.startsWith('/expozitii/');
const isExhibitionDetail =
  normalizedPath === '/exhibition/' || normalizedPath.startsWith('/exhibition/');
const isArtistDetail = normalizedPath === '/artist/' || normalizedPath.startsWith('/artist/');
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteMeta.name,
    url: siteUrl,
    inLanguage: siteMeta.language,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ArtGallery',
    name: siteMeta.name,
    url: siteUrl,
    description: siteMeta.defaultDescription,
    telephone: internationalPhone,
    email: siteContact.email,
    openingHours: siteMeta.openingHours,
    address: {
      '@type': 'PostalAddress',
      addressLocality: siteMeta.city,
      addressRegion: siteMeta.region,
      addressCountry: siteMeta.countryCode,
    },
    areaServed: {
      '@type': 'Country',
      name: siteMeta.countryName,
    },
    hasMap: siteMeta.mapUrl,
  },
];
---

<!doctype html>
<html lang={siteMeta.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <base href={base} />
    <meta name="description" content={metaDescription} />
    <meta
      name="google-site-verification"
      content="iY00fL43fL48AotmfvwA2hOddB6M4uXYbp1Oh5qU27Q"
    />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="author" content={siteMeta.name} />
    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" hrefLang="ro-RO" href={pageUrl} />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:locale" content={siteMeta.locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={pageUrl} />
    {metaImage ? <meta property="og:image" content={metaImage} /> : null}
    <meta name="twitter:card" content={metaImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {metaImage ? <meta name="twitter:image" content={metaImage} /> : null}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    {structuredData.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <button class="back-button" type="button" aria-label="Înapoi" data-visible="false">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M15 5l-7 7 7 7" />
      </svg>
    </button>
    <header class="site-header">
      <div class="site-brand">
        <a href="./" class="site-logo">Galeria Cutare</a>
      </div>
      <nav class="site-nav" aria-label="Principal">
        <a href="expozitii/" class={`nav-link ${isExpoziții ? 'is-active' : ''}`} aria-current={isExpoziții ? 'page' : undefined}>
          Expoziții
        </a>
        <a href="artisti/" class={`nav-link ${isArtisti ? 'is-active' : ''}`} aria-current={isArtisti ? 'page' : undefined}>
          Artiști
        </a>
        <a href="contact/" class={`nav-link ${isContact ? 'is-active' : ''}`} aria-current={isContact ? 'page' : undefined}>
          Contact
        </a>
        <a href="locatii/" class={`nav-link is-hidden ${isLocatii ? 'is-active' : ''}`} aria-current={isLocatii ? 'page' : undefined}>
          Locații
        </a>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Pentru mai multe detalii: {siteContact.phone}</p>
      <p class="footer-location">
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img" focusable="false">
            <path d="M12 2.5c-3.59 0-6.5 2.9-6.5 6.48 0 4.47 6.5 12.52 6.5 12.52s6.5-8.05 6.5-12.52C18.5 5.4 15.59 2.5 12 2.5zm0 8.6a2.12 2.12 0 1 1 0-4.25 2.12 2.12 0 0 1 0 4.25z" />
          </svg>
        </span>
        Câmpulung-Muscel, România
      </p>
      <nav class="footer-links">
        <a href="termeni/">Termeni și Condiții</a>
        <span class="footer-separator">•</span>
        <a href="politica-confidentialitate/">Politică de Confidențialitate</a>
      </nav>
    </footer>

    <button class="scroll-top" type="button" aria-label="Inapoi sus" hidden>
      ↑
    </button>
    <script is:inline>
      const backButton = document.querySelector('.back-button');
      const mobileViewport = window.matchMedia('(max-width: 699px)');
      const mobileBackButtonVisitKey = 'cutare-mobile-back-button-visited';

      const syncBackButtonVisibility = () => {
        if (!backButton) return;

        if (!mobileViewport.matches) {
          backButton.dataset.visible = 'false';
          return;
        }

        let hasVisitedOnMobile = false;

        try {
          hasVisitedOnMobile = window.localStorage.getItem(mobileBackButtonVisitKey) === 'true';

          if (!hasVisitedOnMobile) {
            window.localStorage.setItem(mobileBackButtonVisitKey, 'true');
          }
        } catch {
          hasVisitedOnMobile = true;
        }

        backButton.dataset.visible = hasVisitedOnMobile ? 'true' : 'false';
      };

      syncBackButtonVisibility();
      mobileViewport.addEventListener?.('change', syncBackButtonVisibility);

      backButton?.addEventListener('click', () => {
        if (window.history.length > 1) {
          window.history.back();
          return;
        }
        window.location.href = './';
      });

      const scrollButton = document.querySelector('.scroll-top');
      const toggleScrollButton = () => {
        if (!scrollButton) return;
        scrollButton.hidden = window.scrollY < 300;
      };
      toggleScrollButton();
      window.addEventListener('scroll', toggleScrollButton, { passive: true });
      scrollButton?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
