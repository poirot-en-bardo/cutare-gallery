---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtworkCarousel from '../../components/ArtworkCarousel.astro';
import {
  getAllExhibitions,
  getExhibitionById,
  getExhibitionContent,
} from '../../utils/exhibitions';
import { formatDateRange } from '../../utils/dates';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  return getAllExhibitions().map((exhibition) => ({
    params: { id: exhibition.id },
  }));
}

const { id } = Astro.params as { id: string };
const exhibition = getExhibitionById(id);
if (!exhibition && import.meta.env.DEV) {
  throw new Error(`Exhibition not found: ${id}`);
}
const { rooms, artworks } = exhibition ? getExhibitionContent(exhibition.id) : { rooms: [], artworks: [] };
const roomsWithArtworks = rooms
  .map((room, index) => ({
    ...room,
    number: index + 1,
    artworks: artworks.filter((artwork) => artwork.roomId === room.id),
  }))
  .filter((room) => room.artworks.length > 0);
const isUpcoming = exhibition ? exhibition.status === 'upcoming' || roomsWithArtworks.length === 0 : true;
const sheetId = import.meta.env.PUBLIC_GOOGLE_SHEET_ID ?? '';
const enableSheetMerge = Boolean(sheetId && !isUpcoming);
const descriptionBlocks = exhibition
  ? exhibition.description
      .split(/\n\s*\n/)
      .map((block) => block.trim())
      .filter(Boolean)
  : [];
const spotifyPlaylistUrl =
  exhibition?.id === '2025-1-cupricina'
    ? 'https://open.spotify.com/playlist/5SdlstCJFBpCExLvpLF8xi?si=hd8BDesfTPy_x60kCE1ymQ'
    : null;
---

<BaseLayout
  title={exhibition ? `${exhibition.title} | Galeria Cutare` : 'Expoziție indisponibilă | Galeria Cutare'}
  description={exhibition?.description ?? 'Această expoziție nu este disponibilă momentan.'}
  image={exhibition?.thumbnail}
>
  {!exhibition ? (
    <div class="placeholder-panel">
      <h2>Expoziție indisponibilă</h2>
      <p>Detaliile pentru această expoziție nu pot fi încărcate momentan.</p>
    </div>
  ) : (
    <>
  <section class="exhibition-header">
    <div class="exhibition-hero">
      <div class="poster-frame">
        <img class="poster-image" src={exhibition.thumbnail} alt={exhibition.title} />
      </div>
    </div>
    <div class={`exhibition-summary ${spotifyPlaylistUrl ? 'exhibition-summary--with-spotify' : ''}`}>
      <div class="exhibition-heading-row">
        <h1>{exhibition.title}</h1>
        <div class={`exhibition-title-meta exhibition-title-meta--${exhibition.status}`}>
          <p class="exhibition-dates">{formatDateRange(exhibition.startDate, exhibition.endDate)}</p>
          <p class="exhibition-location">
            <span class="location-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" focusable="false">
                <path d="M12 2.5c-3.59 0-6.5 2.9-6.5 6.48 0 4.47 6.5 12.52 6.5 12.52s6.5-8.05 6.5-12.52C18.5 5.4 15.59 2.5 12 2.5zm0 8.6a2.12 2.12 0 1 1 0-4.25 2.12 2.12 0 0 1 0 4.25z" />
              </svg>
            </span>
            <a class="location-link" href={exhibition.locationMapUrl} target="_blank" rel="noreferrer">
              {exhibition.location}
            </a>
          </p>
        </div>
      </div>
      <div class="exhibition-description-group">
        {(descriptionBlocks.length > 0 ? descriptionBlocks : [exhibition.description]).map((block) => (
          <p class="exhibition-description">{block}</p>
        ))}
        {spotifyPlaylistUrl && (
          <a
            class="spotify-insert"
            href={spotifyPlaylistUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Ascultă playlistul CuPricina pe Spotify"
          >
            <span class="spotify-insert__eyebrow">Playlistul expoziției</span>
            <img
              class="spotify-insert__logo"
              src={withBase('/images/spotify-logo.svg')}
              alt="Spotify"
              loading="lazy"
            />
          </a>
        )}
      </div>
    </div>
  </section>

  {isUpcoming ? (
    <div class="placeholder-panel">
      <h2>În curând</h2>
      <p>Sălile și lucrările vor fi publicate aproape de deschidere.</p>
    </div>
  ) : (
    <section class="timeline room-timeline" aria-label="Sălile expoziției" data-room-timeline>
      <div class="timeline-rail" aria-hidden="true"></div>
      <div class="timeline-list">
        {roomsWithArtworks.map((room) => (
          <div class="timeline-row room-timeline-row" data-room-timeline-row data-room-id={room.id}>
            <div class="timeline-marker room-timeline-marker">
              <span class="timeline-dot" aria-hidden="true"></span>
              <span class="timeline-date room-timeline-date">
                <span class="timeline-date-line">Sala</span>
                <span class="timeline-date-line room-timeline-number">{room.number}</span>
              </span>
            </div>
            <article class="timeline-card room-timeline-card">
              <div class="room-timeline-card-body">
                <ArtworkCarousel artworks={room.artworks} />
              </div>
            </article>
          </div>
        ))}
      </div>
    </section>
  )}

  {!isUpcoming && roomsWithArtworks.length > 0 && (
    <script>
      const rows = Array.from(document.querySelectorAll('[data-room-timeline-row]'));
      const timeline = document.querySelector('[data-room-timeline]');
      const params = new URLSearchParams(window.location.search);
      const requestedArtworkId = params.get('artwork');
      const requestedRoomId = params.get('room');
      let ticking = false;

      const updateActiveRow = () => {
        ticking = false;
        if (!rows.length) return;

        const viewportCenter = window.innerHeight / 2;
        let best = rows[0];
        let bestDistance = Number.POSITIVE_INFINITY;

        for (const row of rows) {
          const rect = row.getBoundingClientRect();
          const rowCenter = rect.top + rect.height / 2;
          const distance = Math.abs(rowCenter - viewportCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            best = row;
          }
        }

        rows.forEach((row) => {
          row.classList.toggle('is-active', row === best);
        });

        if (timeline && best?.dataset?.roomId) {
          timeline.setAttribute('data-active-room', best.dataset.roomId);
        }
      };

      const requestUpdate = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateActiveRow);
      };

      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);
      window.addEventListener('load', requestUpdate);
      requestUpdate();

      if (requestedRoomId || requestedArtworkId) {
        requestAnimationFrame(() => {
          if (requestedRoomId) {
            const room = document.querySelector(`[data-room-id="${requestedRoomId}"]`);
            room?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          if (requestedArtworkId) {
            const card = document.querySelector(`[data-artwork-id="${requestedArtworkId}"]`);
            if (!card) return;
            const row = card.closest('[data-room-id]');
            row?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            requestAnimationFrame(() => {
              card.scrollIntoView({ behavior: 'smooth', block: 'center' });
              card.classList.add('is-highlighted');
              setTimeout(() => card.classList.remove('is-highlighted'), 2200);
            });
          }
        });
      }
    </script>
  )}

  {enableSheetMerge && (
    <script type="module" define:vars={{ sheetId, exhibitionId: id }}>
      import { fetchExhibitionSheet } from '../../utils/fetchSheet';

      const formatPrice = (value) => {
        if (typeof value !== 'number' || Number.isNaN(value)) return null;
        return new Intl.NumberFormat('ro-RO', {
          style: 'currency',
          currency: 'EUR',
          maximumFractionDigits: 0,
        }).format(value);
      };

      const updateCard = (card, row) => {
        const forSale = card.dataset.forSale === 'true';
        const sold = row.sold === true;
        const price = typeof row.price === 'number' ? row.price : null;

        card.dataset.sold = sold ? 'true' : 'false';
        card.dataset.price = price ? String(price) : '';

        const badge = card.querySelector('[data-role="sold-badge"]');
        if (badge) {
          badge.hidden = !sold;
          badge.setAttribute('aria-hidden', sold ? 'false' : 'true');
        }

        const status = card.querySelector('[data-role="artwork-status"]');
        if (!status) return;

        if (sold) {
          status.textContent = 'VANDUT';
        } else if (forSale) {
          status.textContent = formatPrice(price) || 'Preț la cerere';
        } else {
          status.textContent = 'Nu este de vanzare';
        }
      };

      const hydrate = async () => {
        try {
          const data = await fetchExhibitionSheet(sheetId, exhibitionId);
          data.forEach((row) => {
            const card = document.querySelector(`[data-artwork-id="${row.id}"]`);
            if (card) updateCard(card, row);
          });
        } catch (error) {
          console.warn('[exhibition] Could not load live pricing data.', error);
        }
      };

      hydrate();
    </script>
  )}
    </>
  )}
</BaseLayout>
