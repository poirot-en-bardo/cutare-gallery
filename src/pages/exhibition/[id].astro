---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtworkCarousel from '../../components/ArtworkCarousel.astro';
import tiparituriPreviewData from '../../data/exhibitions/2026-5-tiparituri/previews.json';
import { getAllArtists } from '../../utils/artists';
import {
  getAllExhibitions,
  getExhibitionById,
  getExhibitionContent,
} from '../../utils/exhibitions';
import { formatDateRange } from '../../utils/dates';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  return getAllExhibitions().map((exhibition) => ({
    params: { id: exhibition.id },
  }));
}

const { id } = Astro.params as { id: string };
const exhibition = getExhibitionById(id);
if (!exhibition && import.meta.env.DEV) {
  throw new Error(`Exhibition not found: ${id}`);
}
const { rooms, artworks } = exhibition ? getExhibitionContent(exhibition.id) : { rooms: [], artworks: [] };
const roomsWithArtworks = rooms
  .map((room, index) => ({
    ...room,
    number: index + 1,
    artworks: artworks.filter((artwork) => artwork.roomId === room.id),
  }))
  .filter((room) => room.artworks.length > 0);
const isUpcoming = exhibition ? exhibition.status === 'upcoming' || roomsWithArtworks.length === 0 : true;
const sheetId = import.meta.env.PUBLIC_GOOGLE_SHEET_ID ?? '';
const enableSheetMerge = Boolean(sheetId && !isUpcoming);
const descriptionBlocks = exhibition
  ? exhibition.description
      .split(/\n\s*\n/)
      .map((block) => block.trim())
      .filter(Boolean)
  : [];
const allArtists = getAllArtists();
const normalizeLookup = (value: string) =>
  value
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[’']/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
const escapeHtml = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
const artistIdByName = new Map(
  allArtists.map((artist) => [normalizeLookup(artist.name), artist.id])
);
artistIdByName.set('ana-selma duteanu', 'selma-duteanu');
artistIdByName.set('ana selma duteanu', 'selma-duteanu');

const renderInlineMarkup = (value: string) => {
  return escapeHtml(value)
    .replace(/\*\*\*([^*]+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*([^*]+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+?)\*/g, '<em>$1</em>');
};

const renderArtistLinkOrText = (name: string) => {
  const artistId = artistIdByName.get(normalizeLookup(name));
  if (!artistId) return escapeHtml(name);
  const href = escapeHtml(withBase(`/artist/${artistId}/`));
  return `<a class="exhibition-inline-link" href="${href}">${escapeHtml(name)}</a>`;
};

const renderDescriptionLine = (line: string) => {
  const artistListMatch = line.match(/^(?:\*\*)?(Vor participa|Artiști|Artisti)(?:\*\*)?(?::\*\*|:)\s*(.+)$/u);
  if (artistListMatch) {
    const [, label, people] = artistListMatch;
    const renderedPeople = people
      .split('/')
      .map((person) => person.trim())
      .filter(Boolean)
      .map(renderArtistLinkOrText)
      .join(' / ');
    return `<strong>${escapeHtml(label)}</strong>: ${renderedPeople}`;
  }

  const creditsMatch = line.match(/^(?:\*\*)?(Curatori|Design|Playlist)(?:\*\*)?(?::\*\*|:)\s*(.+)$/u);
  if (creditsMatch) {
    const [, label, people] = creditsMatch;
    const renderedPeople = people
      .split(',')
      .map((person) => person.trim())
      .filter(Boolean)
      .map(renderArtistLinkOrText)
      .join(', ');
    return `<strong>${escapeHtml(label)}</strong>: ${renderedPeople}`;
  }

  return renderInlineMarkup(line);
};

const descriptionBlockHtml = (descriptionBlocks.length > 0 ? descriptionBlocks : [exhibition?.description ?? ''])
  .map((block) =>
    block
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map(renderDescriptionLine)
      .join('<br />')
  )
  .filter(Boolean);
const spotifyPlaylistUrls: Record<string, string> = {
  '2025-1-cupricina': 'https://open.spotify.com/playlist/5SdlstCJFBpCExLvpLF8xi?si=hd8BDesfTPy_x60kCE1ymQ',
  '2026-5-tiparituri': 'https://open.spotify.com/playlist/7vlw7pqW9mHFnOtleVtRh7?si=Oy4d8vxlSFSvbtP-H5622Q',
};
const spotifyPlaylistUrl = exhibition ? spotifyPlaylistUrls[exhibition.id] ?? null : null;
const exhibitionVideos: Record<
  string,
  {
    src: string;
    poster?: string;
    title: string;
    creditsHtml: string;
  }
> = {
  '2026-5-tiparituri': {
    src: 'https://res.cloudinary.com/dxyeal4gg/video/upload/v1779532787/video_ducu_compressed_cavh2h.mp4',
    poster: 'https://res.cloudinary.com/dxyeal4gg/video/upload/f_jpg,so_0/v1779532787/video_ducu_compressed_cavh2h.jpg',
    title: 'Video Tipărituri',
    creditsHtml:
      'Filmare și montaj: Dan Duca (<a href="https://atlascultural.org/" target="_blank" rel="noreferrer">Asociația Atlas Cultural</a>)',
  },
};
const exhibitionVideo = exhibition ? exhibitionVideos[exhibition.id] ?? null : null;
type ExhibitionPreviewImage = {
  src?: string;
  alt?: string;
  position?: string;
};
type ExhibitionPreviewGroup = {
  artistId: string;
  images: ExhibitionPreviewImage[];
};
const exhibitionPreviewData: Record<string, ExhibitionPreviewGroup[]> = {
  '2026-5-tiparituri': tiparituriPreviewData as ExhibitionPreviewGroup[],
};
const artistsById = new Map(allArtists.map((artist) => [artist.id, artist]));
const getLastNameKey = (name: string) => name.trim().split(/\s+/).at(-1) ?? name;
const defaultPreviewPositions = ['50% 50%', '22% 48%', '76% 44%'];
const exhibitionPreviewGroups = exhibition
  ? (exhibitionPreviewData[exhibition.id] ?? [])
      .flatMap((group, groupIndex) => {
        const artist = artistsById.get(group.artistId);
        const images = group.images
          .filter(Boolean)
          .slice(0, 3)
          .map((image, imageIndex) => {
            const src = image.src?.trim();
            return {
              src: src ? withBase(src) : '',
              alt: image.alt?.trim() || `${artist?.name ?? 'Artist'}, preview ${imageIndex + 1}`,
              position: image.position?.trim() || defaultPreviewPositions[imageIndex] || '50% 50%',
            };
          });
        if (!artist || images.length === 0) return [];
        return [{
          artist,
          images,
          layout: (groupIndex % 3) + 1,
          lastNameKey: getLastNameKey(artist.name),
        }];
      })
      .sort((a, b) => {
        const lastNameComparison = a.lastNameKey.localeCompare(b.lastNameKey, 'ro', { sensitivity: 'base' });
        if (lastNameComparison !== 0) return lastNameComparison;
        return a.artist.name.localeCompare(b.artist.name, 'ro', { sensitivity: 'base' });
      })
  : [];
---

<BaseLayout
  title={exhibition ? `${exhibition.title} | Galeria Cutare` : 'Expoziție indisponibilă | Galeria Cutare'}
  description={exhibition?.description ?? 'Această expoziție nu este disponibilă momentan.'}
  image={exhibition?.thumbnail}
>
  {!exhibition ? (
    <div class="placeholder-panel">
      <h2>Expoziție indisponibilă</h2>
      <p>Detaliile pentru această expoziție nu pot fi încărcate momentan.</p>
    </div>
  ) : (
    <>
  <section class="exhibition-header">
    <div class="exhibition-hero">
      <div class="poster-frame">
        <img class="poster-image" src={exhibition.thumbnail} alt={exhibition.title} />
      </div>
    </div>
    <div class={`exhibition-summary ${spotifyPlaylistUrl ? 'exhibition-summary--with-spotify' : ''}`}>
      <div class="exhibition-heading-row">
        <h1>{exhibition.title}</h1>
        <div class={`exhibition-title-meta exhibition-title-meta--${exhibition.status}`}>
          <p class="exhibition-dates">{formatDateRange(exhibition.startDate, exhibition.endDate)}</p>
          <p class="exhibition-location">
            <span class="location-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" focusable="false">
                <path d="M12 2.5c-3.59 0-6.5 2.9-6.5 6.48 0 4.47 6.5 12.52 6.5 12.52s6.5-8.05 6.5-12.52C18.5 5.4 15.59 2.5 12 2.5zm0 8.6a2.12 2.12 0 1 1 0-4.25 2.12 2.12 0 0 1 0 4.25z" />
              </svg>
            </span>
            <a class="location-link" href={exhibition.locationMapUrl} target="_blank" rel="noreferrer">
              {exhibition.location}
            </a>
          </p>
        </div>
      </div>
      <div class="exhibition-description-group">
        {descriptionBlockHtml.map((block) => (
          <p class="exhibition-description" set:html={block}></p>
        ))}
        {spotifyPlaylistUrl && (
          <a
            class="spotify-insert"
            href={spotifyPlaylistUrl}
            target="_blank"
            rel="noreferrer"
            aria-label={`Ascultă playlistul ${exhibition.title} pe Spotify`}
          >
            <span class="spotify-insert__eyebrow">Playlistul expoziției</span>
            <img
              class="spotify-insert__logo"
              src={withBase('/images/spotify-logo.svg')}
              alt="Spotify"
              loading="lazy"
            />
          </a>
        )}
      </div>
    </div>
  </section>

  {exhibitionVideo && (
    <section class="exhibition-video-section" aria-label={`Video ${exhibition.title}`}>
      <div class={`exhibition-video-frame ${exhibitionVideo.src ? '' : 'exhibition-video-frame--empty'}`}>
        {exhibitionVideo.src ? (
          <video
            class="exhibition-video"
            controls
            preload="metadata"
            poster={exhibitionVideo.poster ?? exhibition.thumbnail}
            aria-label={exhibitionVideo.title}
          >
            <source src={exhibitionVideo.src} />
          </video>
        ) : (
          <div class="exhibition-video-placeholder" role="img" aria-label={exhibitionVideo.title}>
            <span>Video</span>
          </div>
        )}
      </div>
      <p class="exhibition-video-credits" set:html={exhibitionVideo.creditsHtml}></p>
    </section>
  )}

  {exhibitionPreviewGroups.length > 0 && (
    <section class="tiparituri-preview" aria-label={`Artiști ${exhibition.title}`}>
      <div class="tiparituri-carousel" data-tiparituri-carousel>
        <div class="tiparituri-carousel-window">
          <div class="tiparituri-carousel-track" data-tiparituri-track>
            {exhibitionPreviewGroups.map((group) => (
              <article
                class="tiparituri-carousel-slide"
                data-tiparituri-slide
                aria-label={group.artist.name}
              >
                <div
                  class="tiparituri-carousel-media"
                  data-image-count={group.images.length}
                  data-layout={group.layout}
                >
                  {group.images.map((image) => (
                    <figure
                      class={`tiparituri-preview-tile ${image.src ? '' : 'tiparituri-preview-tile--empty'}`}
                      style={`--preview-position: ${image.position};`}
                    >
                      {image.src ? (
                        <img src={image.src} alt={image.alt} loading="lazy" />
                      ) : (
                        <span aria-hidden="true"></span>
                      )}
                    </figure>
                  ))}
                </div>
                <a class="tiparituri-preview-artist-link" href={withBase(`/artist/${group.artist.id}/`)}>
                  {group.artist.name}
                </a>
              </article>
            ))}
          </div>
        </div>
        <button class="tiparituri-carousel-arrow tiparituri-carousel-arrow--prev" type="button" aria-label="Artist anterior" data-tiparituri-prev>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <button class="tiparituri-carousel-arrow tiparituri-carousel-arrow--next" type="button" aria-label="Artist următor" data-tiparituri-next>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9 6l6 6-6 6" />
          </svg>
        </button>
        <div class="tiparituri-carousel-footer" aria-hidden="true">
          <span class="tiparituri-carousel-count" data-tiparituri-count>01 / {String(exhibitionPreviewGroups.length).padStart(2, '0')}</span>
          <div class="tiparituri-carousel-progress">
            <span data-tiparituri-progress></span>
          </div>
        </div>
      </div>
    </section>
  )}

  {!isUpcoming && (
    <section class="timeline room-timeline" aria-label="Sălile expoziției" data-room-timeline>
      <div class="timeline-rail" aria-hidden="true"></div>
      <div class="timeline-list">
        {roomsWithArtworks.map((room) => (
          <div class="timeline-row room-timeline-row" data-room-timeline-row data-room-id={room.id}>
            <div class="timeline-marker room-timeline-marker">
              <span class="timeline-dot" aria-hidden="true"></span>
              <span class="timeline-date room-timeline-date">
                <span class="timeline-date-line">Sala</span>
                <span class="timeline-date-line room-timeline-number">{room.number}</span>
              </span>
            </div>
            <article class="timeline-card room-timeline-card">
              <div class="room-timeline-card-body">
                <ArtworkCarousel artworks={room.artworks} />
              </div>
            </article>
          </div>
        ))}
      </div>
    </section>
  )}

  {!isUpcoming && roomsWithArtworks.length > 0 && (
    <script>
      const rows = Array.from(document.querySelectorAll('[data-room-timeline-row]'));
      const timeline = document.querySelector('[data-room-timeline]');
      const params = new URLSearchParams(window.location.search);
      const requestedArtworkId = params.get('artwork');
      const requestedRoomId = params.get('room');
      let ticking = false;

      const updateActiveRow = () => {
        ticking = false;
        if (!rows.length) return;

        const viewportCenter = window.innerHeight / 2;
        let best = rows[0];
        let bestDistance = Number.POSITIVE_INFINITY;

        for (const row of rows) {
          const rect = row.getBoundingClientRect();
          const rowCenter = rect.top + rect.height / 2;
          const distance = Math.abs(rowCenter - viewportCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            best = row;
          }
        }

        rows.forEach((row) => {
          row.classList.toggle('is-active', row === best);
        });

        if (timeline && best?.dataset?.roomId) {
          timeline.setAttribute('data-active-room', best.dataset.roomId);
        }
      };

      const requestUpdate = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateActiveRow);
      };

      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);
      window.addEventListener('load', requestUpdate);
      requestUpdate();

      if (requestedRoomId || requestedArtworkId) {
        requestAnimationFrame(() => {
          if (requestedRoomId) {
            const room = document.querySelector(`[data-room-id="${requestedRoomId}"]`);
            room?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          if (requestedArtworkId) {
            const card = document.querySelector(`[data-artwork-id="${requestedArtworkId}"]`);
            if (!card) return;
            const row = card.closest('[data-room-id]');
            row?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            requestAnimationFrame(() => {
              card.scrollIntoView({ behavior: 'smooth', block: 'center' });
              card.classList.add('is-highlighted');
              setTimeout(() => card.classList.remove('is-highlighted'), 2200);
            });
          }
        });
      }
    </script>
  )}

  {enableSheetMerge && (
    <script type="module" define:vars={{ sheetId, exhibitionId: id }}>
      import { fetchExhibitionSheet } from '../../utils/fetchSheet';

      const formatPrice = (value) => {
        if (typeof value !== 'number' || Number.isNaN(value)) return null;
        return new Intl.NumberFormat('ro-RO', {
          style: 'currency',
          currency: 'EUR',
          maximumFractionDigits: 0,
        }).format(value);
      };

      const updateCard = (card, row) => {
        const forSale = card.dataset.forSale === 'true';
        const sold = row.sold === true;
        const price = typeof row.price === 'number' ? row.price : null;

        card.dataset.sold = sold ? 'true' : 'false';
        card.dataset.price = price ? String(price) : '';

        const badge = card.querySelector('[data-role="sold-badge"]');
        if (badge) {
          badge.hidden = !sold;
          badge.setAttribute('aria-hidden', sold ? 'false' : 'true');
        }

        const status = card.querySelector('[data-role="artwork-status"]');
        if (!status) return;

        if (sold) {
          status.textContent = 'VANDUT';
        } else if (forSale) {
          status.textContent = formatPrice(price) || 'Preț la cerere';
        } else {
          status.textContent = 'Nu este de vanzare';
        }
      };

      const hydrate = async () => {
        try {
          const data = await fetchExhibitionSheet(sheetId, exhibitionId);
          data.forEach((row) => {
            const card = document.querySelector(`[data-artwork-id="${row.id}"]`);
            if (card) updateCard(card, row);
          });
        } catch (error) {
          console.warn('[exhibition] Could not load live pricing data.', error);
        }
      };

      hydrate();
    </script>
  )}

  {exhibitionPreviewGroups.length > 1 && (
    <script is:inline>
      const carousel = document.querySelector('[data-tiparituri-carousel]');
      const track = carousel?.querySelector('[data-tiparituri-track]');
      const slides = Array.from(carousel?.querySelectorAll('[data-tiparituri-slide]') ?? []);
      const previousButton = carousel?.querySelector('[data-tiparituri-prev]');
      const nextButton = carousel?.querySelector('[data-tiparituri-next]');
      const count = carousel?.querySelector('[data-tiparituri-count]');
      const progress = carousel?.querySelector('[data-tiparituri-progress]');
      const intervalMs = 3000;
      let currentIndex = 0;
      let timer = 0;

      const setActiveSlide = (index) => {
        if (!track || slides.length === 0) return;
        currentIndex = (index + slides.length) % slides.length;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        slides.forEach((slide, slideIndex) => {
          slide.toggleAttribute('aria-hidden', slideIndex !== currentIndex);
        });
        if (count) {
          count.textContent = `${String(currentIndex + 1).padStart(2, '0')} / ${String(slides.length).padStart(2, '0')}`;
        }
        if (progress) {
          progress.style.transform = `scaleX(${(currentIndex + 1) / slides.length})`;
        }
      };

      const stop = () => {
        if (!timer) return;
        window.clearInterval(timer);
        timer = 0;
      };

      const start = () => {
        stop();
        timer = window.setInterval(() => setActiveSlide(currentIndex + 1), intervalMs);
      };

      previousButton?.addEventListener('click', () => {
        setActiveSlide(currentIndex - 1);
        start();
      });
      nextButton?.addEventListener('click', () => {
        setActiveSlide(currentIndex + 1);
        start();
      });
      carousel?.addEventListener('focusin', stop);
      carousel?.addEventListener('focusout', start);

      setActiveSlide(0);
      start();
    </script>
  )}
    </>
  )}
</BaseLayout>
