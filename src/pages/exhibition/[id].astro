---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FloorSection from '../../components/FloorSection.astro';
import {
  getAllExhibitions,
  getExhibitionById,
  getExhibitionContent,
} from '../../utils/exhibitions';
import { formatDateRange } from '../../utils/dates';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  return getAllExhibitions().map((exhibition) => ({
    params: { id: exhibition.id },
  }));
}

const { id } = Astro.params as { id: string };
const exhibition = getExhibitionById(id);
if (!exhibition && import.meta.env.DEV) {
  throw new Error(`Exhibition not found: ${id}`);
}
const { floors, artworks } = exhibition ? getExhibitionContent(exhibition.id) : { floors: [], artworks: [] };
const isUpcoming = exhibition ? exhibition.status === 'upcoming' || artworks.length === 0 : true;
const sheetId = import.meta.env.PUBLIC_GOOGLE_SHEET_ID ?? '';
const enableSheetMerge = Boolean(sheetId && !isUpcoming);
const descriptionBlocks = exhibition
  ? exhibition.description
      .split(/\n\s*\n/)
      .map((block) => block.trim())
      .filter(Boolean)
  : [];
const spotifyPlaylistUrl =
  exhibition?.id === '2025-1-cupricina'
    ? 'https://open.spotify.com/playlist/5SdlstCJFBpCExLvpLF8xi'
    : null;
---

<BaseLayout
  title={exhibition ? `${exhibition.title} | Galeria Cutare` : 'Expoziție indisponibilă | Galeria Cutare'}
  description={exhibition?.description ?? 'Această expoziție nu este disponibilă momentan.'}
>
  {!exhibition ? (
    <div class="placeholder-panel">
      <h2>Expoziție indisponibilă</h2>
      <p>Detaliile pentru această expoziție nu pot fi încărcate momentan.</p>
    </div>
  ) : (
    <>
  <section class="exhibition-header">
    <div class="exhibition-hero">
      <div class="poster-frame">
        <img class="poster-image" src={exhibition.thumbnail} alt={exhibition.title} />
      </div>
    </div>
    <div class="exhibition-summary">
      <div class="exhibition-heading-row">
        <h1>{exhibition.title}</h1>
        <div class={`exhibition-title-meta exhibition-title-meta--${exhibition.status}`}>
          <p class="exhibition-dates">{formatDateRange(exhibition.startDate, exhibition.endDate)}</p>
          <p class="exhibition-location">
            <span class="location-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" focusable="false">
                <path d="M12 2.5c-3.59 0-6.5 2.9-6.5 6.48 0 4.47 6.5 12.52 6.5 12.52s6.5-8.05 6.5-12.52C18.5 5.4 15.59 2.5 12 2.5zm0 8.6a2.12 2.12 0 1 1 0-4.25 2.12 2.12 0 0 1 0 4.25z" />
              </svg>
            </span>
            <a class="location-link" href={exhibition.locationMapUrl} target="_blank" rel="noreferrer">
              {exhibition.location}
            </a>
          </p>
        </div>
      </div>
      <div class="exhibition-description-group">
        {(descriptionBlocks.length > 0 ? descriptionBlocks : [exhibition.description]).map((block) => (
          <p class="exhibition-description">{block}</p>
        ))}
        {spotifyPlaylistUrl && (
          <a
            class="spotify-insert"
            href={spotifyPlaylistUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Ascultă playlistul CuPricina pe Spotify"
          >
            <span class="spotify-insert__eyebrow">Playlistul expoziției</span>
            <img
              class="spotify-insert__logo"
              src={withBase('/images/spotify-logo.svg')}
              alt="Spotify"
              loading="lazy"
            />
          </a>
        )}
      </div>
    </div>
  </section>

  {!isUpcoming && floors.length > 0 && (
    <nav class="floor-nav" aria-label="Selectare etaj" data-floor-nav>
      {floors.map((floor, index) => (
        <button
          type="button"
          class="floor-button"
          data-floor-button={floor.id}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {floor.name}
        </button>
      ))}
    </nav>
  )}

  {isUpcoming ? (
    <div class="placeholder-panel">
      <h2>În curând</h2>
      <p>Planurile de etaj si lucrarile vor fi publicate aproape de deschidere.</p>
    </div>
  ) : (
    floors.map((floor, index) => (
      <FloorSection
        floorId={floor.id}
        floorName={floor.name}
        rooms={floor.rooms}
        artworks={artworks}
        data-visible={index === 0 ? 'true' : 'false'}
      />
    ))
  )}

  {!isUpcoming && floors.length > 0 && (
    <nav
      class="floor-nav floor-nav-bottom"
      aria-label="Selectare etaj (jos)"
      data-floor-nav
      data-floor-nav-bottom
    >
      {floors.map((floor, index) => (
        <button
          type="button"
          class="floor-button"
          data-floor-button={floor.id}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {floor.name}
        </button>
      ))}
    </nav>
  )}

  {!isUpcoming && floors.length > 0 && (
    <script>
      const navs = Array.from(document.querySelectorAll('[data-floor-nav]'));
      const buttons = navs.flatMap((nav) => Array.from(nav.querySelectorAll('[data-floor-button]')));
      const sections = Array.from(document.querySelectorAll('[data-floor-id]'));
      const params = new URLSearchParams(window.location.search);
      const requestedArtworkId = params.get('artwork');
      const requestedFloorId = params.get('floor');
      const requestedRoomId = params.get('room');
      const isKnownFloor = (floorId) =>
        buttons.some((button) => button.getAttribute('data-floor-button') === floorId);
      const persistFloorInUrl = (floorId) => {
        const url = new URL(window.location.href);
        url.searchParams.set('floor', floorId);
        window.history.replaceState(null, '', `${url.pathname}${url.search}${url.hash}`);
      };

      const setActiveFloor = (floorId) => {
        sections.forEach((section) => {
          const isActive = section.getAttribute('data-floor-id') === floorId;
          section.setAttribute('data-visible', isActive ? 'true' : 'false');
        });
        buttons.forEach((button) => {
          const isActive = button.getAttribute('data-floor-button') === floorId;
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      if (buttons.length > 0) {
        let initialFloorId = buttons[0].getAttribute('data-floor-button');

        if (requestedFloorId && isKnownFloor(requestedFloorId)) {
          initialFloorId = requestedFloorId;
        } else if (requestedArtworkId) {
          const targetCard = document.querySelector(`[data-artwork-id="${requestedArtworkId}"]`);
          const targetFloor = targetCard?.closest('[data-floor-id]')?.getAttribute('data-floor-id');
          if (targetFloor && isKnownFloor(targetFloor)) {
            initialFloorId = targetFloor;
          }
        }

        if (initialFloorId) {
          setActiveFloor(initialFloorId);
        }

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const floorId = button.getAttribute('data-floor-button');
            if (floorId) {
              setActiveFloor(floorId);
              persistFloorInUrl(floorId);
            }

            const clickedBottomNav = button.closest('[data-floor-nav-bottom]');
            if (!floorId || !clickedBottomNav) return;

            requestAnimationFrame(() => {
              const topFloorNav = document.querySelector(
                '[data-floor-nav]:not([data-floor-nav-bottom])'
              );
              if (!topFloorNav) return;
              const siteHeader = document.querySelector('.site-header');
              const headerHeight = siteHeader ? siteHeader.getBoundingClientRect().height : 0;
              const top =
                window.scrollY + topFloorNav.getBoundingClientRect().top - headerHeight - 8;
              window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
            });
          });
        });

        if (requestedRoomId || requestedArtworkId) {
          requestAnimationFrame(() => {
            if (requestedRoomId) {
              const room = document.querySelector(`[data-room-id="${requestedRoomId}"]`);
              room?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            if (requestedArtworkId) {
              const card = document.querySelector(`[data-artwork-id="${requestedArtworkId}"]`);
              if (!card) return;
              card.scrollIntoView({ behavior: 'smooth', block: 'center' });
              card.classList.add('is-highlighted');
              setTimeout(() => card.classList.remove('is-highlighted'), 2200);
            }
          });
        }
      }
    </script>
  )}

  {enableSheetMerge && (
    <script type="module" define:vars={{ sheetId, exhibitionId: id }}>
      import { fetchExhibitionSheet } from '../../utils/fetchSheet';

      const formatPrice = (value) => {
        if (typeof value !== 'number' || Number.isNaN(value)) return null;
        return new Intl.NumberFormat('ro-RO', {
          style: 'currency',
          currency: 'EUR',
          maximumFractionDigits: 0,
        }).format(value);
      };

      const updateCard = (card, row) => {
        const forSale = card.dataset.forSale === 'true';
        const sold = row.sold === true;
        const price = typeof row.price === 'number' ? row.price : null;

        card.dataset.sold = sold ? 'true' : 'false';
        card.dataset.price = price ? String(price) : '';

        const badge = card.querySelector('[data-role="sold-badge"]');
        if (badge) {
          badge.hidden = !sold;
          badge.setAttribute('aria-hidden', sold ? 'false' : 'true');
        }

        const status = card.querySelector('[data-role="artwork-status"]');
        if (!status) return;

        if (sold) {
          status.textContent = 'VANDUT';
        } else if (forSale) {
          status.textContent = formatPrice(price) || 'Preț la cerere';
        } else {
          status.textContent = 'Nu este de vanzare';
        }
      };

      const hydrate = async () => {
        try {
          const data = await fetchExhibitionSheet(sheetId, exhibitionId);
          data.forEach((row) => {
            const card = document.querySelector(`[data-artwork-id="${row.id}"]`);
            if (card) updateCard(card, row);
          });
        } catch (error) {
          console.warn('[exhibition] Could not load live pricing data.', error);
        }
      };

      hydrate();
    </script>
  )}
    </>
  )}
</BaseLayout>
