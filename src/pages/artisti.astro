---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllArtists } from '../utils/artists';
import { withBase } from '../utils/withBase';

const artists = getAllArtists();
const previewBio = (value: string) => value.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1');
---

<BaseLayout title="Artiști | Galeria Cutare" description="Descoperă artiștii din galeria Cutare">
  <section class="hero">
    <h1 class="accent-title accent-title--decorated">Artiști</h1>
  </section>

  <div class="artist-search" data-artist-search>
    <div class="artist-search-field">
      <input
        id="artist-search-input"
        class="artist-search-input"
        type="search"
        placeholder="Caută artiști..."
        autocomplete="off"
      />
      <span class="artist-search-icon" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          role="img"
          focusable="false"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="6.5" />
          <path d="M20 20l-3.5-3.5" />
        </svg>
      </span>
    </div>
  </div>

  <section class="artists-grid">
    {artists.map((artist) => (
      <a
        href={withBase(`/artist/${artist.id}/`)}
        class="artist-card"
        data-artist-card
        data-artist-name={artist.name}
        data-artist-id={artist.id}
      >
        <div class="artist-card-image">
          <img src={withBase(artist.photoUrl)} alt={artist.name} loading="lazy" />
        </div>
        <div class="artist-card-content">
          <h2 class="artist-card-name">{artist.name}</h2>
          <p class="artist-card-bio">{previewBio(artist.bio)}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  const searchInput = document.querySelector('#artist-search-input');
  const cards = Array.from(document.querySelectorAll('[data-artist-card]'));

  const adjustBioClamps = () => {
    cards.forEach((card) => {
      if (card.style.display === 'none') return;
      const nameEl = card.querySelector('.artist-card-name');
      const bioEl = card.querySelector('.artist-card-bio');
      if (!nameEl || !bioEl) return;

      // Reset to 2 lines to measure accurately
      bioEl.style.webkitLineClamp = '2';
      
      const styles = getComputedStyle(nameEl);
      let lh = parseFloat(styles.lineHeight);
      if (isNaN(lh)) {
        // Fallback if lineHeight is 'normal'
        lh = parseFloat(styles.fontSize) * 1.2;
      }
      
      // Check if name is multi-line
      const isMultiLine = nameEl.offsetHeight > lh * 1.5;
      
      bioEl.style.webkitLineClamp = isMultiLine ? '1' : '2';
    });
  };

  const normalize = (value) => {
    if (!value) return '';
    return value
      .toString()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();
  };

  const updateCards = () => {
    const query = normalize(searchInput?.value || '');
    cards.forEach((card) => {
      const name = normalize(card.getAttribute('data-artist-name'));
      const id = normalize(card.getAttribute('data-artist-id'));
      const isMatch = !query || name.includes(query) || id.includes(query);
      card.style.display = isMatch ? '' : 'none';
    });
    adjustBioClamps();
  };

  if (searchInput) {
    searchInput.addEventListener('input', updateCards);
  }

  // Initial adjustment
  adjustBioClamps();
  
  // Update on resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(adjustBioClamps, 100);
  });
</script>

<style>
.artists-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin-top: 2rem;
}

@media (min-width: 700px) {
  .artists-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
}

@media (min-width: 1000px) {
  .artists-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
}

.artist-card {
  position: relative;
  display: block;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
  aspect-ratio: 1 / 1;
}

.artist-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow);
  transform: translateY(-4px);
}

.artist-card:hover .artist-card-image img {
  transform: scale(1.05);
}

.artist-card-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: var(--paper);
}

.artist-card-image::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.3) 40%, transparent 100%);
  pointer-events: none;
  z-index: 1;
}

.artist-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
}

.artist-card-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0.5rem 0.4rem 0.4rem;
  z-index: 2;
}

.artist-card-name {
  font-family: 'Cormorant Garamond', 'Times New Roman', serif;
  font-size: 1.2rem;
  font-weight: 600;
  line-height: 1.2;
  margin: 0 0 0.15rem;
  color: #fff;
  text-shadow: 0 1px 12px rgba(0, 0, 0, 0.45);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.artist-card-bio {
  margin: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.7rem;
  line-height: 1.3;
  text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

@media (min-width: 700px) {
  .artist-card-content {
    padding: 1.1rem 0.9rem 0.9rem;
  }

  .artist-card-name {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .artist-card-bio {
    font-size: 0.85rem;
    line-height: 1.4;
  }
}
</style>
