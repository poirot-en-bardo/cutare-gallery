---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllArtists } from '../utils/artists';
import { withBase } from '../utils/withBase';

const artists = getAllArtists();
---

<BaseLayout title="Artiști | Galeria Cutare" description="Descoperă artiștii din galeria Cutare">
  <section class="hero">
    <h1 class="accent-title accent-title--decorated">Artiști</h1>
    <p>Descoperă artiștii care au expus până acum în galeria noastră:</p>
  </section>

  <div class="artist-search" data-artist-search>
    <div class="artist-search-field">
      <input
        id="artist-search-input"
        class="artist-search-input"
        type="search"
        placeholder="Caută artiști..."
        autocomplete="off"
      />
      <span class="artist-search-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <circle cx="11" cy="11" r="6.5" />
          <path d="M20 20l-3.5-3.5" />
        </svg>
      </span>
    </div>
  </div>

  <section class="artists-grid">
    {artists.map((artist) => (
      <a
        href={`artist/${artist.id}/`}
        class="artist-card"
        data-artist-card
        data-artist-name={artist.name}
        data-artist-id={artist.id}
      >
        <div class="artist-card-image">
          <img src={withBase(artist.photoUrl)} alt={artist.name} loading="lazy" />
        </div>
        <div class="artist-card-content">
          <h2 class="artist-card-name">{artist.name}</h2>
          <p class="artist-card-bio">{artist.bio}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  const searchInput = document.querySelector('#artist-search-input');
  const cards = Array.from(document.querySelectorAll('[data-artist-card]'));

  const normalize = (value) => {
    if (!value) return '';
    return value
      .toString()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();
  };

  const updateCards = () => {
    const query = normalize(searchInput?.value || '');
    cards.forEach((card) => {
      const name = normalize(card.getAttribute('data-artist-name'));
      const id = normalize(card.getAttribute('data-artist-id'));
      const isMatch = !query || name.includes(query) || id.includes(query);
      card.style.display = isMatch ? '' : 'none';
    });
  };

  if (searchInput) {
    searchInput.addEventListener('input', updateCards);
  }
</script>

<style>
.artist-search {
  margin: 1.75rem auto 0;
  display: flex;
  justify-content: center;
}

.artist-search-field {
  width: min(560px, 100%);
  position: relative;
}

.artist-search-input {
  width: 100%;
  padding: 0.9rem 3rem 0.9rem 1.4rem;
  border-radius: 999px;
  border: 1px solid rgba(93, 78, 123, 0.2);
  background: linear-gradient(140deg, rgba(255, 255, 255, 0.98), rgba(247, 243, 236, 0.85));
  font-family: 'Newsreader', 'Times New Roman', serif;
  font-size: 1.05rem;
  color: var(--ink);
  box-shadow: 0 16px 32px rgba(17, 17, 17, 0.08);
  transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
}

.artist-search-input::placeholder {
  color: color-mix(in srgb, var(--accent) 45%, var(--muted));
  letter-spacing: 0.02em;
}

.artist-search-input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 18px 36px rgba(17, 17, 17, 0.12),
    0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
  transform: translateY(-1px);
}

.artist-search-icon {
  position: absolute;
  right: 1.1rem;
  top: 50%;
  transform: translateY(-50%);
  width: 18px;
  height: 18px;
  color: color-mix(in srgb, var(--accent) 55%, var(--muted));
  opacity: 0.6;
  pointer-events: none;
}

.artist-search-icon svg {
  width: 100%;
  height: 100%;
  stroke: currentColor;
  stroke-width: 1.8;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.artists-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  margin-top: 2rem;
}

@media (min-width: 700px) {
  .artists-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1000px) {
  .artists-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.artist-card {
  display: flex;
  flex-direction: column;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
}

.artist-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow);
  transform: translateY(-4px);
}

.artist-card-image {
  width: 100%;
  height: 280px;
  overflow: hidden;
  background: var(--paper);
}

.artist-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.artist-card-content {
  padding: 1.5rem;
}

.artist-card-name {
  font-family: 'Cormorant Garamond', 'Times New Roman', serif;
  font-size: 1.6rem;
  font-weight: 600;
  margin: 0 0 0.75rem;
  color: var(--accent);
}

.artist-card-bio {
  margin: 0;
  color: var(--muted-readable);
  font-size: 0.95rem;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
