---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllArtists, getArtistById } from '../../utils/artists';
import { getAllExhibitions, getExhibitionContent } from '../../utils/exhibitions';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  return getAllArtists().map((artist) => ({
    params: { id: artist.id },
  }));
}

const { id } = Astro.params as { id: string };
const artist = getArtistById(id);
if (!artist && import.meta.env.DEV) {
  throw new Error(`Artist not found: ${id}`);
}
const artworksByArtist = artist ? getAllExhibitions().flatMap((exhibition) => {
  const { artworks } = getExhibitionContent(exhibition.id);
  return artworks
    .filter((artwork) => artwork.artist.id === artist.id)
    .map((artwork) => ({
      displayPrice: (() => {
        const normalizedPrice = artwork.price?.trim().toLowerCase();
        const isPriceOnRequest = normalizedPrice
          ? ['la cerere', 'pret la cerere', 'preț la cerere'].includes(normalizedPrice)
          : false;
        return {
          value: isPriceOnRequest ? 'Preț la cerere' : artwork.price,
          isOnRequest: isPriceOnRequest,
        };
      })(),
      artworkId: artwork.id,
      artworkTitle: artwork.title,
      exhibitionId: exhibition.id,
      exhibitionTitle: exhibition.title,
      floorId: artwork.floorId,
      roomId: artwork.roomId,
      artworkImage: withBase(artwork.imageUrl),
      year: artwork.year,
      description: artwork.description,
      price: artwork.price,
      sold: artwork.sold,
    }));
}) : [];

const photoUrl = artist ? withBase(artist.photoUrl) : '';
---

<BaseLayout
  title={artist ? `${artist.name} | Galeria Cutare` : 'Artist indisponibil | Galeria Cutare'}
  description={artist?.bio ?? 'Pagina artistului nu este disponibilă momentan.'}
>
  {!artist ? (
    <div class="placeholder-panel">
      <h2>Artist indisponibil</h2>
      <p>Profilul artistului nu poate fi încărcat momentan.</p>
    </div>
  ) : (
  <section class="artist-profile">
    <div class="artist-photo-wrap">
      <img class="artist-photo" src={photoUrl} alt={artist.name} loading="lazy" />
    </div>
    <div>
      <h1 class="artist-name">{artist.name}</h1>
      <p class="artist-bio">{artist.bio}</p>
      <p class="artist-contact-line">
        <span class="artist-contact-label">Contact:</span>{' '}
        <span>{artist.contact}</span>
      </p>

    </div>
  </section>
  )}

  {artist && artworksByArtist.length > 0 && (
    <section class="artist-gallery">
      <div class="artist-search" data-artwork-search>
        <div class="artist-search-field">
          <input
            class="artist-search-input"
            type="search"
            placeholder="Caută lucrări..."
            autocomplete="off"
            aria-label="Caută lucrări"
            data-artwork-search-input
          />
          <span class="artist-search-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              role="img"
              focusable="false"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="6.5" />
              <path d="M20 20l-3.5-3.5" />
            </svg>
          </span>
        </div>
      </div>
      <h2 class="artist-works-title">Lucrări disponibile</h2>
      <div class="artist-gallery-grid">
        {artworksByArtist.map((artwork) => (
          <a
            href={`exhibition/${artwork.exhibitionId}/?floor=${artwork.floorId}&room=${artwork.roomId}&artwork=${artwork.artworkId}`}
            class="artist-gallery-item"
            data-artwork-card
            data-artwork-title={artwork.artworkTitle}
            data-artwork-year={artwork.year ?? ''}
            data-artwork-description={artwork.description ?? ''}
            data-artwork-exhibition={artwork.exhibitionTitle ?? ''}
          >
            <div class="artist-gallery-image">
              <img src={artwork.artworkImage} alt={artwork.artworkTitle} loading="lazy" />
              {artwork.sold && (
                <span class="sold-badge">VÂNDUT</span>
              )}
            </div>
            <div class="artist-gallery-info">
              <h3 class="artist-gallery-title">{artwork.artworkTitle}</h3>
              {artwork.year && <p class="artist-gallery-year">{artwork.year}</p>}
              {artwork.description && (
                <p class="artist-gallery-description">{artwork.description}</p>
              )}
              {artwork.displayPrice?.value && (
                <p
                  class={`artist-gallery-price ${artwork.sold ? 'is-sold' : ''} ${artwork.displayPrice.isOnRequest ? 'is-on-request' : ''}`}
                >
                  {artwork.displayPrice.value}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<script is:inline>
  const artworkSearchInput = document.querySelector('[data-artwork-search-input]');
  const artworkCards = Array.from(document.querySelectorAll('[data-artwork-card]'));

  const normalizeText = (value) => {
    if (!value) return '';
    return value
      .toString()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();
  };

  const updateArtworkCards = () => {
    const query = normalizeText(artworkSearchInput?.value || '');
    artworkCards.forEach((card) => {
      const title = normalizeText(card.getAttribute('data-artwork-title'));
      const year = normalizeText(card.getAttribute('data-artwork-year'));
      const description = normalizeText(card.getAttribute('data-artwork-description'));
      const exhibition = normalizeText(card.getAttribute('data-artwork-exhibition'));
      const isMatch =
        !query ||
        title.includes(query) ||
        year.includes(query) ||
        description.includes(query) ||
        exhibition.includes(query);
      card.style.display = isMatch ? '' : 'none';
    });
  };

  if (artworkSearchInput) {
    artworkSearchInput.addEventListener('input', updateArtworkCards);
  }
</script>

<style>
.artist-gallery {
  margin-top: calc(1.75rem + 0.35rem);
  padding-top: 1.75rem;
  border-top: 1px solid var(--line);
}

@media (max-width: 600px) {
  .artist-gallery {
    margin-top: calc(1.5rem + 0.22rem);
    padding-top: 1.5rem;
  }

  .artist-search {
    margin-top: 0.22rem;
  }
}

.artist-gallery-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  margin-top: 1.5rem;
}

@media (min-width: 600px) {
  .artist-gallery-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 900px) {
  .artist-gallery-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.artist-gallery-item {
  display: flex;
  flex-direction: column;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
}

.artist-gallery-item:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow);
  transform: translateY(-4px);
}

.artist-gallery-image {
  position: relative;
  width: 100%;
  height: 280px;
  background: #f5f4f3;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.artist-gallery-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.artist-gallery-image .sold-badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: var(--ink);
  color: #fff;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  padding: 0.35rem 0.6rem;
  border-radius: 999px;
}

.artist-gallery-info {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.artist-gallery-title {
  font-family: 'Newsreader', 'Times New Roman', serif;
  font-size: 1.3rem;
  font-weight: 600;
  margin: 0;
  color: var(--ink);
}

.artist-gallery-year {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  color: var(--muted);
  margin: 0;
}

.artist-gallery-description {
  font-size: 0.95rem;
  color: var(--muted-readable);
  line-height: 1.4;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.artist-gallery-price {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--highlight);
  margin: 0.5rem 0 0;
}

.artist-gallery-price.is-on-request {
  font-family: inherit;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.artist-gallery-price.is-sold {
  color: var(--ink);
  background: var(--line);
  padding: 0.35rem 0.6rem;
  border-radius: 6px;
  display: inline-block;
  width: fit-content;
}
</style>
